# feishu_opc 环境变量模板
#
# 使用步骤：
#   1. cp .env.example .env
#   2. 打开根目录 README.md →「环境变量说明」表格，对照「轻度」必填项填写
#   3. 重度能力再展开下方「第二节」与 .larkagent/secrets/ 下各 *.example 文件
#
# 切勿将已填写真实密钥的 .env 提交到 git。

# =============================================================================
# 一、轻度使用 — 单机器人 + 对话 + LLM（与 README「轻度」一致）
# =============================================================================

DEBUG=false
# 生产环境请改为足够长的随机串（README 环境变量表）
SECRET_KEY=请改为随机长字符串

# 可选：显式指定本仓库根（一般可不写）
# APP_REPO_ROOT=/path/to/feishu_opc

# —— 飞书机器人（与 README 表格一致；亦可拆到 .larkagent/secrets/feishu_bot/*.env）——
FEISHU_BOT_APP_ID=cli_你的应用AppID
FEISHU_BOT_APP_SECRET=你的AppSecret
FEISHU_VERIFICATION_TOKEN=事件订阅校验Token
FEISHU_ENCRYPT_KEY=事件消息加密Key

# —— 大模型：仅 OpenAI 兼容 HTTP（与 README「大模型」一节一致；勿改 source）——
TECHBOT_LLM_SOURCE=openai_compatible
TECHBOT_LLM_API_KEY=
# 示例：https://api.openai.com/v1/chat/completions（或你的兼容网关完整 URL）
TECHBOT_LLM_BASE_URL=
TECHBOT_LLM_MODEL=
# TECHBOT_LLM_TIMEOUT_SECONDS=30

# 填完本节即可按 README「安装」启动；未配置的进阶能力会缺省或报错提示。

# =============================================================================
# 二、重度使用 — 在「一」的基础上按需取消注释并填写
# =============================================================================

# DEFAULT_PROJECT_ID=

# 分角色飞书应用（参见 .larkagent/secrets/feishu_bot/*.example.env）
# TECH_LEAD_FEISHU_BOT_APP_ID=
# TECH_LEAD_FEISHU_BOT_APP_SECRET=
# TECH_LEAD_FEISHU_VERIFICATION_TOKEN=
# TECH_LEAD_FEISHU_ENCRYPT_KEY=
# PRODUCT_MANAGER_FEISHU_BOT_APP_ID=
# PRODUCT_MANAGER_FEISHU_BOT_APP_SECRET=

# 多维表格（或 bitable.env）
# FEISHU_DEFAULT_BITABLE_APP_TOKEN=
# FEISHU_DEFAULT_BITABLE_TABLE_ID=

# 委派 / 真人代发（参见 application_agent.example.env）
# APPLICATION_AGENT_OPEN_ID=
# APPLICATION_AGENT_GROUP_CHAT_ID=
# APPLICATION_AGENT_DISPLAY_NAME=Application delegate

# 以下仅为「默认模型名」覆盖，仍走同一 OpenAI 兼容网关（与 TECHBOT_LLM_* 同一套端点）
# ROLE_AGENT_DEFAULT_MODEL=
# OPENCLAW_DEFAULT_MODEL=

# OAuth 回调（运行 oauth_callback_server 时）
# OAUTH_CALLBACK_PUBLIC_URL=https://你的域名/feishu/callback
# IMPERSONATION_AUTHORIZE_URL=https://你的域名/feishu/authorize?app=application_agent
