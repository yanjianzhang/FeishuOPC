# Feishu event subscription
FEISHU_VERIFICATION_TOKEN=your_verification_token
FEISHU_ENCRYPT_KEY=your_encrypt_key

# Feishu Bitable target
# app_id/app_secret come from each bot's own *.env; the server now auto-fetches
# app_access_token via /auth/v3/app_access_token/internal when no user token is set.
FEISHU_DEFAULT_BITABLE_APP_TOKEN=your_bitable_app_token
FEISHU_DEFAULT_BITABLE_TABLE_ID=your_bitable_table_id
BITABLE_BASE_URL=https://open.feishu.cn/open-apis/bitable/v1/apps/your_bitable_app_token

# Optional: only keep this if your Bitable writes require user auth
FEISHU_DEFAULT_USER_ACCESS_TOKEN=your_user_access_token

# Optional: Tech Bot overrides
# Usually not needed if server auto-loads .larkagent/secrets/ai_key/.env + model_sources.json
TECHBOT_LLM_SOURCE=aws_bedrock
TECHBOT_LLM_CONFIG_PATH=/app/runtime-resources/.larkagent/secrets/ai_key/model_sources.json
TECHBOT_LLM_ENV_PATH=/app/runtime-resources/.larkagent/secrets/ai_key/.env
TECHBOT_LLM_TIMEOUT_SECONDS=30
TECHBOT_RUN_LOG_DIR=server/data/techbot-runs
TECHBOT_ALLOW_REPO_STATE_WRITES=true
