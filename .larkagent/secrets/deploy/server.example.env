# Copy to server.env and fill in. Do not commit real credentials.
LARK_SERVER_HOST=
LARK_SERVER_PORT=22
LARK_SERVER_USER=ubuntu
# SSH key auth (preferred) - path to private key on this machine
LARK_SERVER_KEY=~/.ssh/your_lark_server_key.pem
# Public webhook/API domain for the Feishu agent host
LARK_SERVER_URL=api.example.com
# Default remote project layout
LARK_PROJECT_NAME=exampleapp
LARK_PROJECTS_ROOT=/home/ubuntu/projects
# Optional override for roles config file
# LARK_ROLES_FILE=.larkagent/secrets/deploy/roles.jsonl
# Password auth (fallback, requires sshpass) - uncomment if needed
# LARK_SERVER_PASSWORD=
