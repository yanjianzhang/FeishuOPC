# Per-project code-write policies. One JSON object per line.
#
# Precedence & merging:
# - If this file exists and has an entry for a project, it OVERRIDES the
#   minimal built-in default (empty allowed_write_roots → fail-closed).
# - Missing fields inherit from the default.
# - ``denied_path_segments`` is ALWAYS unioned with the hardcoded baseline
#   (.env / .git / secrets / .key / .pem / id_ed25519 / id_rsa). You cannot
#   turn those off from this file.
# - ``project_repo_root`` is optional; if omitted, it falls back to the
#   ``project_repo_root`` declared in ``projects/projects.jsonl`` for the
#   same ``project_id``.
# - Lines beginning with "#" and blank lines are ignored.
# - A single malformed line aborts the whole file load (refuse to half-load
#   a security policy).
#
# Rename this file to policies.jsonl and adjust values. The production file
# is gitignored; this example is committed.
#
# The example below is one concrete Flutter+tools shape — treat it as a
# template, not as a default. Every deployment writes its own.
#
# `validation_commands` (optional) is the local mirror of the project's
# CI checks: every entry runs as part of `run_pre_push_inspection`; any
# non-zero exit or timeout becomes a `kind=validation_failed, severity=blocker`
# issue and refuses the push. This is what stops "code looked fine in
# review but tsc fails in GitHub Actions" from leaking through. Each entry:
#   - name             (required, str)  — human label; appears in the blocker `path`
#   - cmd              (required, list[str]) — argv, run WITHOUT a shell
#   - cwd              (optional, str)  — sub-dir relative to project_repo_root; defaults to repo root
#   - timeout_seconds  (optional, int>0) — defaults to 120
# Empty array (or absent field) preserves legacy behavior: only secret /
# path / size checks run. Wire just the gates that already gate CI; do
# NOT add slow integration suites here — pre-push has to stay fast.
{"project_id":"exampleapp","project_repo_root":"~/Documents/Github/ExampleApp","allowed_write_roots":["example_app/lib/","example_app/test/","example_app/integration_test/","example_app/assets/data/","miniapp/","server/","tools/","shared/","docs/"],"allowed_read_roots":["example_app/","miniapp/","server/","tools/","shared/","docs/","specs/","stories/","reviews/","_bmad/",".cursor/commands/",".specify/","README.md"],"denied_path_segments":[".env",".git","secrets","id_ed25519","id_rsa",".pem",".key","node_modules",".dart_tool","build/",".venv","deploy/"],"hard_max_bytes_per_file":524288,"require_confirmation_above_bytes":65536,"max_files_per_write_batch":30,"validation_commands":[{"name":"miniapp-typecheck","cmd":["npm","--prefix","miniapp","run","typecheck"],"timeout_seconds":120}]}
