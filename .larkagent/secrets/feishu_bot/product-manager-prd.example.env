# Feishu bot credentials for the product manager bot
AppID=your_feishu_bot_app_id
AppSecret=your_feishu_bot_app_secret
FEISHU_VERIFICATION_TOKEN=your_product_manager_verification_token
FEISHU_ENCRYPT_KEY=your_product_manager_encrypt_key

