# Optional: separate Feishu app used for Bitable / workspace delegation
# (impersonation OAuth + delegate_to_application_agent targets).
# Copy to application_agent.env (gitignored) and fill real values.
#
# AppName maps to APPLICATION_AGENT_DISPLAY_NAME (shown in @mentions).

AppName=Application delegate
AppID=cli_your_delegate_app_id
AppSecret=your_delegate_app_secret

APPLICATION_AGENT_OPEN_ID=ou_your_delegate_bot_open_id
APPLICATION_AGENT_GROUP_CHAT_ID=oc_your_target_group_chat_id

# Optional: HTTP webhook instead of or in addition to IM paths
# APPLICATION_AGENT_DELEGATE_URL=https://example.com/your-delegate/inbox

# Optional: tech-lead bot open_id for reply threading in webhook payloads
# TECH_LEAD_BOT_OPEN_ID=ou_your_tech_lead_bot_open_id

# Optional impersonation overrides (defaults fall back to AppID / AppSecret above)
# IMPERSONATION_APP_ID=
# IMPERSONATION_APP_SECRET=
# IMPERSONATION_ENABLED=true
# IMPERSONATION_TOKEN_DIR=.larkagent/secrets/user_tokens
