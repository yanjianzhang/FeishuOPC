# MCP servers manifest — one JSON object per line.
#
# Copy to ``mcp_servers.jsonl`` (same dir) and set
#   MCP_SERVERS_CONFIG_PATH=.larkagent/secrets/mcp/mcp_servers.jsonl
# on the runtime.
#
# Reference: docs/ops/tier2-harness.md §2.

# Feishu lark-cli MCP — exposes lark-* operations as tools.
# Requires ``lark-cli`` to already be on PATH + authenticated.
# {"name": "lark", "command": ["lark-cli", "mcp", "serve"]}

# Filesystem notes MCP (example).
# {"name": "notes", "command": ["npx", "-y", "notes-mcp"], "env": {"NOTES_DIR": "/srv/notes"}}

# Disabled server — config retained but skipped at boot.
# {"name": "wip", "command": ["node", "wip-mcp.js"], "enabled": false}
